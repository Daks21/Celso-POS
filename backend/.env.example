# Celso POS — backend environment template.
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.
#   cp .env.example .env   (or copy it in your editor)
#
# On Railway/Render, set these as platform environment variables instead of a
# file. Point the DB_* values at your managed MySQL (e.g. DB_HOST=${{MySQL.MYSQLHOST}}).

# ── Required — the server exits on boot if any of these are missing ──
JWT_SECRET=replace-with-a-64+char-cryptographically-random-string
DB_HOST=localhost
DB_PORT=3306
DB_USER=celsopos_app
DB_PASS=your_db_password
DB_NAME=celsopos_db
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Optional — defaults shown ──
PORT=3000
# CORS origin(s), comma-separated. With single-origin web hosting, same-origin
# requests don't need it, but set it to your production domain anyway.
FRONTEND_URL=http://localhost:5173
JWT_EXPIRES_IN=1d
DB_POOL_SIZE=5
AI_CACHE_TTL_SEC=300
AI_MAX_TOKENS=600
# AI_MODEL=llama-3.3-70b-versatile

# ── Optional AI fallback (DeepSeek activates only on Groq 429/503) ──
# DEEPSEEK_API_KEY=sk-your_deepseek_key

# ── Billing — manual GCash bridge (Phase 6.6) ──
# No payment-provider keys are needed: owners pay a GCash QR and submit the
# reference number in-app; the platform super-admin approves claims in admin.html.
# Configure the receiving QR + account name/number from the super-admin dashboard
# (stored in the platform_config table), not via env.
#
# Optional — consumed ONLY by the one-off scripts/create-superadmin.js seed
# (not read at runtime). You can also pass these as CLI args instead.
# SUPERADMIN_EMAIL=you@example.com
# SUPERADMIN_PASSWORD=use-a-long-random-password
