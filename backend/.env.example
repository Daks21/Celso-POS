# Celso POS — backend environment template.
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.
#   cp .env.example .env   (or copy it in your editor)
#
# On Railway/Render, set these as platform environment variables instead of a
# file. Point the DB_* values at your managed MySQL (e.g. DB_HOST=${{MySQL.MYSQLHOST}}).

# ── Required — the server exits on boot if any of these are missing ──
JWT_SECRET=replace-with-a-64+char-cryptographically-random-string
DB_HOST=localhost
DB_PORT=3306
DB_USER=celsopos_app
DB_PASS=your_db_password
DB_NAME=celsopos_db
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Optional — defaults shown ──
PORT=3000
# CORS origin(s), comma-separated. With single-origin web hosting, same-origin
# requests don't need it, but set it to your production domain anyway.
FRONTEND_URL=http://localhost:5173
JWT_EXPIRES_IN=1d
DB_POOL_SIZE=5
AI_CACHE_TTL_SEC=300
AI_MAX_TOKENS=600
# AI_MODEL=llama-3.3-70b-versatile

# ── Optional AI fallback (DeepSeek activates only on Groq 429/503) ──
# DEEPSEEK_API_KEY=sk-your_deepseek_key

# ── Billing — Lemon Squeezy (Phase 6.5; OPTIONAL — the server boots without it,
#    and the /api/billing endpoints return 503 until these are set) ──
# Create a store + a "Celso POS" product with two subscription variants (Plus,
# Pro). Do everything in LS TEST mode first; tunnel webhooks with `ngrok http 3000`
# and set APP_URL to the ngrok https URL while testing. In prod, APP_URL = your
# public domain (the Phase 7 Railway/Render URL).
# LEMONSQUEEZY_API_KEY=lsq_test_xxxxxxxx
# LEMONSQUEEZY_STORE_ID=12345
# LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_signing_secret
# LS_VARIANT_PLUS=111111
# LS_VARIANT_PRO=222222
# APP_URL=https://your-ngrok-or-domain
